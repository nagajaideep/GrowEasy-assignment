# ---- Server ----
PORT=4000
NODE_ENV=development
# CORS: set to your frontend origin in production, e.g. https://your-app.vercel.app
CORS_ORIGIN=*
MAX_UPLOAD_MB=10

# ---- AI provider ----
# One of: gemini | openai | mock
# If omitted, it auto-detects from the keys below and falls back to "mock".
AI_PROVIDER=

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---- Batch processing ----
AI_BATCH_SIZE=20
AI_MAX_RETRIES=3
